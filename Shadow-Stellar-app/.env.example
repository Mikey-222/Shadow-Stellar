# Shadow-Stellar App Environment Variables
#
# Copy this file to .env and fill in the values after deploying contracts.
#   cp .env.example .env
#
# To generate: run `scripts/deploy-testnet.sh` which outputs these values.

# Testnet RPC endpoint (defaults to Soroban testnet)
VITE_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Deployed contract IDs (from deploy-testnet.sh output)
VITE_CCP_CONTRACT_ID=CCP_CONTRACT_ID_HERE
VITE_ZCP_CONTRACT_ID=ZCP_CONTRACT_ID_HERE

# Network passphrase (testnet | mainnet)
VITE_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Optional: UltraHonk verifier contract (set if using zk-SNARK proofs)
# VITE_ULTRAHONK_VERIFIER_ID=
